# ── Required by inference.py ──────────────────────────────────
HF_TOKEN=your_hugging_face_token_here
OPENAI_API_KEY=your_api_key_here
API_BASE_URL=https://router.huggingface.co/v1
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
ENV_URL=http://localhost:7860
MAX_TOKENS=1500
N_REPEATS=3

